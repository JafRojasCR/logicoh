# URI de conexión a MongoDB Atlas
MONGODB_URI=mongodb+srv://<usuario>:<contraseña>@<cluster>.mongodb.net/logicoh?retryWrites=true&w=majority

# Nombre de la base de datos (opcional, por defecto: logicoh)
MONGODB_DB_NAME=logicoh

# Nombre de colección (opcional, por defecto: conceptos)
MONGODB_COLLECTION=conceptos

# Origen CORS permitido (opcional, por defecto: *)
CORS_ORIGIN=*

# Puerto local para desarrollo API (opcional, por defecto: 3001)
API_PORT=3001
